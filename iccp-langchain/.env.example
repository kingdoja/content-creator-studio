# ===========================================
# 必填项（模型调用至少需要）
# ===========================================
# LLM - 必填：大模型 API 密钥
OPENAI_API_KEY=your-openai-api-key

# ===========================================
# 可选 - LLM 其他配置（有默认值）
# ===========================================
# 使用 OpenAI 时：
# OPENAI_MODEL=gpt-4
# LLM_BASE_URL=https://api.openai.com/v1
# IMAGE_MODEL=gpt-image-1

# 使用通义千问 qwen-turbo 时，直接填下面即可（变量名不变）：
OPENAI_MODEL=qwen-turbo
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# OPENAI_API_KEY 填你在阿里云 DashScope 控制台拿到的 API Key（sk- 开头）

# 封面图生成（通义千问场景下填下面其一，与上面同一套 API Key）：
# IMAGE_MODEL=qwen-image-max   （推荐，画质最好）
# IMAGE_MODEL=qwen-image-plus （画质次之）
# IMAGE_MODEL=qwen-image       （画质最差）

# ===========================================
# 可选 - 文生视频配置（新功能）
# ===========================================
# mock: 只做剧情润色 + Prompt 生成，不调用视频接口
# seedance: 使用火山引擎 Seedance 专用协议
VIDEO_PROVIDER=mock
VIDEO_MODEL=doubao-seedance-1-0-pro-fast-251015
VIDEO_TIMEOUT=180
VIDEO_POLL_INTERVAL=2
VIDEO_SAVE_LOCAL=true

# Seedance 专用配置（VIDEO_PROVIDER=seedance 时使用）
SEEDANCE_BASE_URL=https://operator.las.cn-beijing.volces.com
# 不填时会回退使用 OPENAI_API_KEY（建议单独配置）
SEEDANCE_API_KEY=

LLM_TIMEOUT=60
LLM_TEMPERATURE=0.7

# ===========================================
# 可选 - 工具 API（不配也能跑）
# ===========================================
# 网络搜索：不填则使用 DuckDuckGo 备用
TAVILY_API_KEY=your-tavily-api-key

# MCP 桥接（默认关闭）
# 开启后可把外部 MCP 工具接入现有 ToolRegistry（推荐通过网关统一鉴权/限流）
MCP_ENABLED=false
# MCP 网关地址（示例），需实现 POST /tools/call
MCP_GATEWAY_URL=
# 默认 MCP server 名称（可被 MCP_TOOLS_JSON 内单项覆盖）
MCP_DEFAULT_SERVER=
# JSON 数组，定义要注册的 MCP 工具
# 示例：
# MCP_TOOLS_JSON=[{"name":"news_search","description":"新闻检索","server":"cursor-ide-browser","mcp_tool":"WebSearch","input_arg_key":"query"}]
MCP_TOOLS_JSON=

# ===========================================
# 可选 - 应用配置
# ===========================================
APP_NAME=ICCP LangChain API
DEBUG=False
VERSION=1.0.0

# CORS（前端地址），多域名用逗号分隔
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# ===========================================
# 以下为已支持的工程化配置（可按需修改）
# ===========================================
# 数据库（默认本地 sqlite，生产建议 PostgreSQL）
DATABASE_URL=sqlite+aiosqlite:///./iccp.db
DATABASE_SYNC_URL=sqlite:///./iccp.db

# RAG 配置
RAG_EMBEDDING_MODEL=text-embedding-3-small
RAG_CHUNK_SIZE=1000
RAG_CHUNK_OVERLAP=200
RAG_TOP_K=4
RAG_VECTOR_BACKEND=memory
RAG_MILVUS_COLLECTION=knowledge_chunks
RAG_MILVUS_METRIC=IP

# 记忆与视频超时保护（防卡住）
# 记忆召回超时后自动降级为空记忆，不中断主流程
MEMORY_RECALL_TIMEOUT_SECONDS=6
# 视频剧情润色超时后返回可解释错误
VIDEO_POLISH_TIMEOUT_SECONDS=30

# Redis（缓存/扩展任务队列）
REDIS_URL=redis://localhost:6379/0

# JWT（当前未接入）
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
ADMIN_EMAILS=admin@example.com

# Milvus（当前未接入）
MILVUS_HOST=localhost
MILVUS_PORT=19530

# Celery（当前未接入）
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_BACKEND_URL=redis://localhost:6379/2

RATE_LIMIT_PER_MINUTE=10

# LangSmith（可观测性）
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=iccp-langchain

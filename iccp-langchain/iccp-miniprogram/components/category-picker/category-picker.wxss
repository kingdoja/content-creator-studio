.picker-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20rpx;
}

.picker-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 24rpx 8rpx;
  border-radius: 20rpx;
  background: #f9fafb;
  border: 2rpx solid transparent;
  transition: all 0.2s;
}

.picker-item.active {
  background: rgba(99, 102, 241, 0.08);
  border-color: var(--cat-color, #6366f1);
}

.picker-icon {
  font-size: 44rpx;
  margin-bottom: 8rpx;
}

.picker-name {
  font-size: 22rpx;
  color: #374151;
  text-align: center;
}

.picker-item.active .picker-name {
  color: var(--cat-color, #6366f1);
  font-weight: 600;
}

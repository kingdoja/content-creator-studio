/* ========== 全局样式 ========== */
page {
  --primary: #6366f1;
  --primary-light: #818cf8;
  --primary-dark: #4f46e5;
  --bg: #f5f5f5;
  --bg-card: #ffffff;
  --text: #1f2937;
  --text-secondary: #6b7280;
  --text-muted: #9ca3af;
  --border: #e5e7eb;
  --success: #10b981;
  --warning: #f59e0b;
  --danger: #ef4444;
  --radius: 16rpx;
  --radius-lg: 24rpx;
  --shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);

  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  font-size: 28rpx;
  color: var(--text);
  background-color: var(--bg);
  box-sizing: border-box;
}

.container {
  padding: 24rpx 32rpx;
}

.card {
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  padding: 32rpx;
  box-shadow: var(--shadow);
  margin-bottom: 24rpx;
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text);
  margin-bottom: 16rpx;
}

.card-desc {
  font-size: 24rpx;
  color: var(--text-secondary);
  line-height: 1.6;
}

.btn-primary {
  background: linear-gradient(135deg, var(--primary), var(--primary-dark));
  color: #fff;
  border: none;
  border-radius: var(--radius);
  padding: 20rpx 40rpx;
  font-size: 28rpx;
  font-weight: 500;
  text-align: center;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-primary::after {
  border: none;
}

.btn-primary[disabled] {
  opacity: 0.5;
}

.btn-outline {
  background: transparent;
  color: var(--primary);
  border: 2rpx solid var(--primary);
  border-radius: var(--radius);
  padding: 18rpx 36rpx;
  font-size: 28rpx;
  font-weight: 500;
  text-align: center;
}

.btn-outline::after {
  border: none;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text);
  margin-bottom: 20rpx;
  padding-left: 4rpx;
}

.divider {
  height: 1rpx;
  background: var(--border);
  margin: 24rpx 0;
}

.flex-row {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.flex-between {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
}

.ellipsis {
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}

.tag {
  display: inline-block;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  background: rgba(99, 102, 241, 0.1);
  color: var(--primary);
}

.input-area {
  width: 100%;
  min-height: 160rpx;
  font-size: 28rpx;
  line-height: 1.6;
  color: #1f2937;
  padding: 0;
}

.options-row {
  display: flex;
  gap: 24rpx;
  margin-bottom: 32rpx;
}

.option-item {
  flex: 1;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.option-label {
  font-size: 24rpx;
  color: #6b7280;
  display: block;
  margin-bottom: 12rpx;
}

.option-picker {
  font-size: 28rpx;
  color: #1f2937;
  font-weight: 500;
}

.generate-btn {
  width: 100%;
  height: 88rpx;
  font-size: 32rpx;
  margin-top: 8rpx;
}

/* 结果 */
.result-section {
  padding-bottom: 40rpx;
}

.result-meta {
  display: flex;
  align-items: center;
}

.video-wrapper {
  margin-bottom: 28rpx;
  border-radius: 16rpx;
  overflow: hidden;
}

.video-player {
  width: 100%;
  height: 420rpx;
}

.no-video-tip {
  background: #f9fafb;
  border-radius: 12rpx;
  padding: 40rpx;
  margin-bottom: 28rpx;
  text-align: center;
}

.tip-text {
  font-size: 26rpx;
  color: #9ca3af;
}

.storyline-section {
  margin-bottom: 28rpx;
}

.storyline-label {
  font-size: 26rpx;
  font-weight: 600;
  color: #374151;
  display: block;
  margin-bottom: 12rpx;
}

.storyline-content {
  background: #f9fafb;
  border-radius: 12rpx;
  padding: 24rpx;
  font-size: 26rpx;
  line-height: 1.8;
  color: #374151;
}

.result-actions {
  display: flex;
  gap: 20rpx;
}

.result-actions .btn-primary,
.result-actions .btn-outline {
  flex: 1;
  height: 80rpx;
}

/* 错误 */
.error-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 40rpx;
}

.error-icon {
  font-size: 64rpx;
  margin-bottom: 20rpx;
}

.error-text {
  font-size: 28rpx;
  color: #ef4444;
  text-align: center;
  line-height: 1.6;
}

/* 进度遮罩 */
.overlay {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0, 0, 0, 0.45);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
}

.overlay-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 60rpx 80rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.12);
  min-width: 440rpx;
}

.spinner {
  display: flex;
  gap: 16rpx;
  margin-bottom: 32rpx;
}

.dot {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  background: #6366f1;
  animation: bounce 1.4s infinite ease-in-out both;
}

.dot1 { animation-delay: -0.32s; }
.dot2 { animation-delay: -0.16s; }
.dot3 { animation-delay: 0s; }

@keyframes bounce {
  0%, 80%, 100% { transform: scale(0); opacity: 0.4; }
  40% { transform: scale(1); opacity: 1; }
}

.overlay-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #1f2937;
  margin-bottom: 16rpx;
}

.overlay-sub {
  font-size: 24rpx;
  color: #9ca3af;
  margin-top: 16rpx;
}

.progress-bar-wrap {
  width: 360rpx;
  height: 12rpx;
  background: #e5e7eb;
  border-radius: 6rpx;
  overflow: hidden;
}

.progress-bar {
  height: 100%;
  background: linear-gradient(90deg, #6366f1, #818cf8);
  border-radius: 6rpx;
  transition: width 0.5s ease;
}

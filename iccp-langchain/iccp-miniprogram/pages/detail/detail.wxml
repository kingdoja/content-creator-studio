<view class="container">
  <view wx:if="{{loading}}" class="loading-hint">
    <text>加载中...</text>
  </view>

  <view wx:elif="{{item}}">
    <!-- 头部信息 -->
    <view class="detail-header card">
      <text class="detail-topic">{{item.topic}}</text>
      <view class="detail-meta">
        <view class="tag" style="background: {{item.cat.color}}15; color: {{item.cat.color}};">
          {{item.cat.icon}} {{item.cat.name}}
        </view>
        <text class="detail-agent">Agent: {{item.agent}}</text>
        <text class="detail-time">{{item.timeLabel}}</text>
      </view>
      <view wx:if="{{item.tools_used && item.tools_used.length > 0}}" class="detail-tools">
        <text class="tools-label">使用工具：</text>
        <text wx:for="{{item.tools_used}}" wx:key="*this" class="tag tool-tag">{{item}}</text>
      </view>
    </view>

    <!-- 内容正文 -->
    <view class="detail-body card">
      <text class="detail-content" selectable="true">{{item.content}}</text>
    </view>

    <!-- 操作按钮 -->
    <view class="detail-actions">
      <button class="btn-primary" bindtap="handleCopy">复制全文</button>
      <button class="btn-outline" open-type="share">分享给好友</button>
    </view>
  </view>
</view>

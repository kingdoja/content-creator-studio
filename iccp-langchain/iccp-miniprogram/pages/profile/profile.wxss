.profile-card {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, #6366f1, #4f46e5);
  border-radius: 24rpx;
  padding: 40rpx 32rpx;
  margin-bottom: 28rpx;
}

.avatar-wrap {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 28rpx;
  flex-shrink: 0;
}

.avatar-text {
  font-size: 44rpx;
  color: #fff;
  font-weight: 700;
}

.profile-info {
  display: flex;
  flex-direction: column;
}

.profile-name {
  font-size: 34rpx;
  font-weight: 600;
  color: #fff;
  margin-bottom: 6rpx;
}

.profile-email {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.75);
}

/* 统计 */
.stats-row {
  display: flex;
  background: #fff;
  border-radius: 20rpx;
  padding: 32rpx 0;
  margin-bottom: 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  border-right: 1rpx solid #f3f4f6;
}

.stat-item:last-child {
  border-right: none;
}

.stat-num {
  font-size: 40rpx;
  font-weight: 700;
  color: #6366f1;
  margin-bottom: 6rpx;
}

.stat-label {
  font-size: 22rpx;
  color: #9ca3af;
}

/* 菜单 */
.menu-section {
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  margin-bottom: 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid #f3f4f6;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  font-size: 36rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.menu-text {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.menu-title {
  font-size: 28rpx;
  color: #1f2937;
  font-weight: 500;
}

.menu-desc {
  font-size: 22rpx;
  color: #9ca3af;
  margin-top: 4rpx;
}

.menu-arrow {
  font-size: 36rpx;
  color: #d1d5db;
  flex-shrink: 0;
}

/* 操作区 */
.action-section {
  margin-bottom: 40rpx;
}

.action-btn {
  width: 100%;
  height: 88rpx;
}

.footer {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 0 40rpx;
}

.footer-text {
  font-size: 22rpx;
  color: #9ca3af;
}

.footer-ver {
  font-size: 20rpx;
  color: #d1d5db;
  margin-top: 4rpx;
}

<view class="container">
  <!-- 用户卡片 -->
  <view class="profile-card">
    <view class="avatar-wrap">
      <text class="avatar-text">{{userInfo.username ? userInfo.username[0] : '?'}}</text>
    </view>
    <view class="profile-info">
      <text class="profile-name">{{userInfo.username || '未登录用户'}}</text>
      <text class="profile-email">{{userInfo.email || '点击登录体验完整功能'}}</text>
    </view>
  </view>

  <!-- 统计 -->
  <view class="stats-row">
    <view class="stat-item">
      <text class="stat-num">{{stats.totalCreations}}</text>
      <text class="stat-label">创作数</text>
    </view>
    <view class="stat-item">
      <text class="stat-num">7</text>
      <text class="stat-label">可用板块</text>
    </view>
    <view class="stat-item">
      <text class="stat-num">3</text>
      <text class="stat-label">Agent</text>
    </view>
  </view>

  <!-- 菜单 -->
  <view class="menu-section">
    <view
      wx:for="{{menuItems}}"
      wx:key="id"
      class="menu-item"
      bindtap="onMenuTap"
      data-url="{{item.url}}"
    >
      <text class="menu-icon">{{item.icon}}</text>
      <view class="menu-text">
        <text class="menu-title">{{item.title}}</text>
        <text wx:if="{{item.desc}}" class="menu-desc">{{item.desc}}</text>
      </view>
      <text wx:if="{{item.url}}" class="menu-arrow">›</text>
    </view>
  </view>

  <!-- 登录/退出 -->
  <view class="action-section">
    <button wx:if="{{!userInfo}}" class="btn-primary action-btn" bindtap="handleLogin">
      微信快捷登录
    </button>
    <button wx:else class="btn-outline action-btn" bindtap="handleLogout">
      退出登录
    </button>
  </view>

  <view class="footer">
    <text class="footer-text">ICCP 智能创作平台 · 多Agent协作</text>
    <text class="footer-ver">v1.0.0</text>
  </view>
</view>

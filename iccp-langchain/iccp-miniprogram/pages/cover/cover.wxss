.title-input {
  width: 100%;
  min-height: 100rpx;
  font-size: 28rpx;
  line-height: 1.6;
  color: #1f2937;
  padding: 0;
}

.options-row {
  display: flex;
  gap: 24rpx;
  margin-bottom: 32rpx;
}

.option-item {
  flex: 1;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.option-label {
  font-size: 24rpx;
  color: #6b7280;
  display: block;
  margin-bottom: 12rpx;
}

.option-picker {
  font-size: 28rpx;
  color: #1f2937;
  font-weight: 500;
}

.generate-btn {
  width: 100%;
  height: 88rpx;
  font-size: 32rpx;
  margin-top: 8rpx;
}

.result-section {
  padding-bottom: 40rpx;
}

.cover-preview {
  margin-bottom: 28rpx;
  border-radius: 16rpx;
  overflow: hidden;
}

.cover-image {
  width: 100%;
  display: block;
}

.prompt-row {
  background: #f9fafb;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 28rpx;
}

.prompt-label {
  font-size: 24rpx;
  color: #6b7280;
  display: block;
  margin-bottom: 8rpx;
}

.prompt-text {
  font-size: 24rpx;
  color: #374151;
  line-height: 1.6;
}

.result-actions {
  display: flex;
  gap: 20rpx;
}

.result-actions .btn-primary,
.result-actions .btn-outline {
  flex: 1;
  height: 80rpx;
}

.error-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 40rpx;
}

.error-icon {
  font-size: 64rpx;
  margin-bottom: 20rpx;
}

.error-text {
  font-size: 28rpx;
  color: #ef4444;
  text-align: center;
  line-height: 1.6;
}

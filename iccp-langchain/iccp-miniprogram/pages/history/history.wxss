.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 160rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 30rpx;
  color: #6b7280;
  margin-bottom: 8rpx;
}

.empty-sub {
  font-size: 24rpx;
  color: #9ca3af;
}

.history-item {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.hist-left {
  margin-right: 20rpx;
  flex-shrink: 0;
}

.hist-icon-wrap {
  width: 72rpx;
  height: 72rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.hist-icon {
  font-size: 36rpx;
}

.hist-center {
  flex: 1;
  min-width: 0;
}

.hist-topic {
  font-size: 28rpx;
  font-weight: 500;
  color: #1f2937;
  display: block;
  margin-bottom: 8rpx;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}

.hist-meta {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-wrap: wrap;
}

.hist-agent {
  font-size: 22rpx;
  color: #6b7280;
}

.hist-time {
  font-size: 22rpx;
  color: #9ca3af;
}

.hist-right {
  flex-shrink: 0;
  margin-left: 12rpx;
}

.hist-arrow {
  font-size: 36rpx;
  color: #d1d5db;
}
